# ============================================================
# NEXIA CRM TEMPLATE — environment variables
# Copy to .env.local (or run `npm run setup` to auto-generate).
# ============================================================

# === SUPABASE (per-project) ===
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Direct DB access (for scripts/backfill — pooler session mode)
# Supabase Dashboard → Project Settings → Database → Connection string
DB_POOLER_HOST=aws-1-sa-east-1.pooler.supabase.com
DB_POOLER_USER=postgres.<project-ref>
DB_PASSWORD=...

# === UAZAPI (WhatsApp, per-project) ===
UAZAPI_URL=https://<instance>.uazapi.com
UAZAPI_TOKEN=...

# === AI PROVIDERS ===
# Required: Anthropic for Carol (main LLM)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: Groq for audio transcription during WhatsApp backfill
GROQ_API_KEY=gsk_...

# Optional: Gemini for sentiment classification on inbound messages
GOOGLE_API_KEY=AIza...

# Optional: Anthropic Admin API (shows credit usage in /crm/config)
ANTHROPIC_ADMIN_KEY=sk-ant-admin-...

# === INTERNAL ===
# Generated once by setup.mjs — used by the DB webhook trigger to auth /api/leads/new
WEBHOOK_SECRET=...

# === AIOX Variables (added 2026-05-28) ===
# Cost: ~$0.14/M tokens with tool calling support
DEEPSEEK_API_KEY=
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# OpenAI API Key - Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Get your key at: https://exa.ai/
EXA_API_KEY=
# Usually free, no key required for basic usage
CONTEXT7_API_KEY=
# Get from your Supabase project settings
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=
# Get from: ClickUp Settings > Apps > API Token
CLICKUP_API_KEY=
# From your N8N instance settings
N8N_API_KEY=
N8N_WEBHOOK_URL=
# Sentry (error tracking)
SENTRY_DSN=
# Railway (deployment)
RAILWAY_TOKEN=
# Vercel (deployment)
VERCEL_TOKEN=
# --------------------------------------------
NODE_ENV=development
AIOX_VERSION=5.2.9

# AIOX_NOTE: The following variables already exist with different values:
# AIOX_SUGGESTED: ANTHROPIC_API_KEY=
# AIOX_SUGGESTED: SUPABASE_SERVICE_ROLE_KEY=
